# {{ ansible_managed }}
# nginx site for serving OSM extracts (PLAN.md §A5).
#
# Ships working over HTTP so `nginx -t` passes before any cert exists. Add TLS
# with certbot (`certbot --nginx -d {{ osm_download_hostname }}`), which injects the
# ssl_certificate lines and an HTTP->HTTPS redirect into the server block below.

server {
    listen 80;
    listen [::]:80;
    server_name {{ osm_download_hostname }};

    root {{ osm_root }}/extracts;
    autoindex off;

    # Serve .json inline; everything else (incl. .pbf) as a binary download.
    types {
        application/json json;
    }
    default_type application/octet-stream;

    location / {
        add_header Accept-Ranges bytes;            # resumable large downloads
        add_header Cache-Control "public, max-age=3600";
        # Last-Modified comes from the file mtime (= extract time); the sibling
        # status.json carries the authoritative data-age fields.
        try_files $uri =404;
    }
}

